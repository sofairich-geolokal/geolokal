{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "DATABASE_URL": "@database_url",
    "DB_HOST": "@db_host",
    "DB_PORT": "@db_port",
    "DB_USER": "@db_user",
    "DB_PASSWORD": "@db_password",
    "DB_NAME": "@db_name",
    "DB_SSL_MODE": "require",
    "NODE_ENV": "production",
    "NEXT_PUBLIC_GEOSERVER_URL": "@next_public_geoserver_url"
  }
}
