generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TaxParcel {
  id         Int       @id @default(autoincrement())
  parcel_no  String    @unique @db.VarChar(50)
  owner_name String?   @db.VarChar(100)
  valuation  Decimal?  @db.Decimal(15, 2)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("tax_parcels")
}

model CbmsIndicator {
  id              Int       @id @default(autoincrement())
  indicator_code  String    @db.VarChar(20)
  indicator_value Decimal?  @db.Decimal(10, 2)
  status          String?   @db.VarChar(20)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@map("cbms_indicators")
}

model User {
  id               Int               @id @default(autoincrement())
  username         String            @unique @db.VarChar(50)
  email            String            @unique @db.VarChar(100)
  password_hash    String
  role             String?           @db.VarChar(20)
  lgu_id           Int?
  createdAt        DateTime?         @default(now()) @map("created_at") @db.Timestamp(6)
  created_by       String?           @db.VarChar(50)
  last_login       DateTime?         @default(now()) @db.Timestamptz(6)
  is_active        Boolean?          @default(true)
  audit_logs       AuditLog[]
  map_layers       map_layers[]
  city_muni_master city_muni_master? @relation(fields: [lgu_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("users")
}

model AuditLog {
  id               Int               @id @default(autoincrement())
  timestamp        DateTime?         @default(now()) @db.Timestamp(6)
  actor_id         Int?
  action           String?           @db.VarChar(100)
  details          String?
  lgu_id           Int?
  actor            String?
  created_by       String?
  users            User?             @relation(fields: [actor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  city_muni_master city_muni_master? @relation(fields: [lgu_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("audit_logs")
}

model city_muni_master {
  id         Int          @id @default(autoincrement())
  name       String       @unique @db.VarChar(100)
  province   String?      @db.VarChar(100)
  created_at DateTime?    @default(now()) @db.Timestamp(6)
  audit_logs AuditLog[]
  map_layers map_layers[]
  projects   projects[]
  users      User[]
}

model map_layers {
  id                 Int                      @id @default(autoincrement())
  lgu_id             Int?
  category_id        Int?
  layer_name         String                   @db.VarChar(100)
  geom               Unsupported("geometry")?
  metadata           Json?
  uploaded_by        Int?
  created_at         DateTime?                @default(now()) @db.Timestamp(6)
  project_categories project_categories?      @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  city_muni_master   city_muni_master?        @relation(fields: [lgu_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users              User?                    @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([geom], map: "idx_map_layers_geom", type: Gist)
}

model project_categories {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(100)
  map_layers map_layers[]
  projects   projects[]
}

model projects {
  id                 Int                 @id @default(autoincrement())
  lgu_id             Int?
  category_id        Int?
  project_name       String              @db.VarChar(255)
  description        String?
  status             String?             @db.VarChar(50)
  created_at         DateTime?           @default(now()) @db.Timestamp(6)
  project_categories project_categories? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  city_muni_master   city_muni_master?   @relation(fields: [lgu_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

model system_status {
  id             Int       @id @default(autoincrement())
  server_name    String?   @default("Main-Server") @db.VarChar(50)
  last_reboot    DateTime? @default(dbgenerated("(CURRENT_TIMESTAMP - '156:00:00'::interval)")) @db.Timestamptz(6)
  is_online      Boolean?  @default(true)
  last_heartbeat DateTime? @default(now()) @db.Timestamptz(6)
}
